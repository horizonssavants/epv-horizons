  "faq": [
    { "id": "faq-1", "question": "Quels sont les horaires de l'école ?",               "reponse": "Lundi au vendredi : 7h30–16h45 (primaire) et 7h30–12h30 (maternelle). Les portes ouvrent à 7h00 pour l'accueil.", "cat": "Organisation", "ordre": 1, "publie": true,  "createdAt": "2026-01-01T00:00:00Z" },
    { "id": "faq-2", "question": "Comment se déroule l'admission ?",                   "reponse": "3 étapes : pré-inscription en ligne, entretien pédagogique avec l'équipe, puis dépôt du dossier complet au secrétariat avec règlement des frais d'inscription.", "cat": "Admission",    "ordre": 2, "publie": true,  "createdAt": "2026-01-01T00:00:00Z" },
    { "id": "faq-3", "question": "L'école propose-t-elle un service de transport ?",  "reponse": "Oui, ramassage scolaire disponible sur les axes Cocody, Riviera, Bingerville et Plateau. Tarifs sur demande au secrétariat.", "cat": "Services",     "ordre": 3, "publie": true,  "createdAt": "2026-01-01T00:00:00Z" },
    { "id": "faq-4", "question": "Quelle est la politique de bilinguisme ?",           "reponse": "Enseignement de l'anglais dès la Petite Section — minimum 8 heures par semaine par des enseignants diplômés et certifiés en enseignement bilingue.", "cat": "Pédagogie",    "ordre": 4, "publie": true,  "createdAt": "2026-01-01T00:00:00Z" },
    { "id": "faq-5", "question": "Y a-t-il une cantine scolaire ?",                   "reponse": "Oui, menus équilibrés validés mensuellement par une diététicienne. Le coût de la cantine est inclus dans les frais de scolarité.", "cat": "Services",     "ordre": 5, "publie": true,  "createdAt": "2026-01-01T00:00:00Z" },
    { "id": "faq-6", "question": "Comment contacter l'administration ?",               "reponse": "Téléphone : 07 78 98 14 56 · Email : contact@horizonssavants.com · Formulaire de contact disponible sur le site.", "cat": "Organisation", "ordre": 6, "publie": true,  "createdAt": "2026-01-01T00:00:00Z" },
    { "id": "faq-7", "question": "Des bourses ou réductions sont-elles disponibles ?", "reponse": "Programme de parrainage : jusqu'à 40% de réduction cumulable (10% par filleul inscrit). Facilités de paiement en 3 trimestres.", "cat": "Finances",     "ordre": 7, "publie": true,  "createdAt": "2026-01-01T00:00:00Z" },
    { "id": "faq-8", "question": "Que faire en cas d'absence de l'enfant ?",          "reponse": "Informer l'administration avant 8h00 par téléphone ou via l'Espace Parent. Un justificatif médical est requis pour toute absence dépassant 2 jours.", "cat": "Organisation", "ordre": 8, "publie": false, "createdAt": "2026-01-01T00:00:00Z" }
  ],


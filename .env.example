# BASE DE DONNÉES — Neon PostgreSQL (connexion directe via pg driver)
# https://console.neon.tech → Connexion → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon REST API (PostgREST) — optionnel
# https://console.neon.tech → REST API → récupérer anon key et service_role key
NEON_REST_URL=https://ep-xxx.apirest.c-7.us-east-1.aws.neon.tech/neondb/rest/v1
NEON_REST_ANON_KEY=
NEON_REST_SERVICE_KEY=

# APP_URL: URL de l'application en production
APP_URL="http://localhost:3000"

# RESEND: Fournisseur d'emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# TWILIO: WhatsApp via Twilio (option 1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# META / WHATSAPP BUSINESS API: WhatsApp direct (option 2)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

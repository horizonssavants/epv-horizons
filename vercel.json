{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/admin",
      "headers": { "Location": "/#/admin" },
      "status": 301
    },
    {
      "src": "/espace-parent",
      "headers": { "Location": "/#/espace-parent" },
      "status": 301
    },
    {
      "src": "/img/(.*)",
      "dest": "/img/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
